{
  "name": "tidapp-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Tidrapporteringsapp backend för svenska hantverks-/byggföretag",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "prisma migrate deploy && tsx prisma/seed-if-empty.ts && node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:safe": "tsx prisma/seed-if-empty.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.8.4",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/web-push": "^3.6.4",
    "prisma": "^5.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
