DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
JWT_SECRET="change-this-to-a-long-random-secret"
FRONTEND_URL="https://your-cloudflare-pages-domain.pages.dev"
EXTRA_CORS_ORIGINS=""
PORT=3001
UPLOAD_DIR="./uploads"
# Sätt till true om publika företag/admin-registreringar ska tillåtas i produktion.
ALLOW_PUBLIC_REGISTRATION=false
# Sätt bara till true om gamla publika /uploads-länkar absolut måste fungera.
PUBLIC_UPLOADS_ENABLED=false
# Skapa nyckelparet en gång med `npx web-push generate-vapid-keys --json`.
WEB_PUSH_PUBLIC_KEY=""
WEB_PUSH_PRIVATE_KEY=""
WEB_PUSH_CONTACT="https://tid.anderssonsisolering.se"
# Samma slumpade token ska sparas som GitHub Actions-secret.
REMINDER_JOB_TOKEN=""
